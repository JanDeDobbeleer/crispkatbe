  <article>
    <h1>Keep Calm and Carry On</h1>

    <p class="date"><time>25<sup>th</sup> December 2023</time>, 185 words</p>

    <p class="author"><a href="/about" rel="author">Aidan Fitzpatrick</a></p>

    <!--<section class="social">
